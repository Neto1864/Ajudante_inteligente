<!DOCTYPE html> <!-- linha excencial -->

<html lang="pt-BR">
<head> 
    <meta charset="UTF-8">
    <title>Assistente Virtual</title> <!-- nome que fica na aba do navegador -->
</head>

<body>
    
    <main>
        <!-- Comando de voz -->
        <section id="comando_voz">
            <button id="btn_escutar" type="button" aria_label="Menu interativo com a IA"> Clique aqui para conversar com o assistente </button>
            <p id="status_de_conexao">
                Ouvindo,
                Analisando,
                Respondendo,
                Esperando,
            </p>
        </section>

        <!-- Upload e comparação de imagens -->
         <section id="analise_img">
            <label for="carregar_img1"> Arquivo cliente </label>
            <input type="file" id="carregar_img1" accept="image/*, .pdf">
            <img id="primeiro_arquivo" src="" alt="Previa do arquivo 1" style="display:nano; max_width: 200px;">

            <label for="carregar_img2"> Arquivo pessoal </label>
            <input type="file" id="carregar_img2" accept="image/*, .pdf">
            <img id="segundo_arquivo" src="" alt="Previa do arquivo 2" style="display:nano; max_width: 200px;">

            <button id="btn_envio_imagens">Analisar Imagens</button>
         </section>

         <!-- Exibindo resultados da IA -->
         <section id="resposta_IA">
            <h2>Respondendo a sua ordem</h2>            
            <div id="resposta_do_comando"></div>
         </section>

        <!-- Banco de Dados Local -->
         <section id="DB_Local">
            <h2> Banco de Dados Local </h2>

            <div id="painel_lgpd">
                <span id="painel_seguranca"> Banco de dados rodando 100% offline</span>
            </div>

            <table id="tabela_privada">
                <thead> <!-- Table Head (THead), cabeçalho da tabela onde fica separado as estrutura em linhas e colunas -->
                    <tr> 
                        <th>Código</th>
                        <th>Descrição</th>
                        <th>Disponibilidade</th>
                        <th>Quantidade</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
         </section>

         <section id="guia_balao_relevante" class="guia_baloes">
            <h2> Agendamentos e Lembretes </h2>

            <div id="balao_diario" class="">
                <span id="" class=""></span>
                <span id="" class=""></span>
            </div>
         </section>

    </main>

    <footer> @Assistente Virtual, @NETO </footer>
</body>
